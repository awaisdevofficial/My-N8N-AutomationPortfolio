        2272
      ]
    },
    {
      "parameters": {
        "jsCode": "// Increment retry count\nconst currentRetry = $('Set Prompt & Config1').item.json.retryCount || 0;\nconst maxRetries = $('Set Prompt & Config1').item.json.maxRetries || 30;\nconst status = $input.item.json.status;\n\nreturn {\n  json: {\n    ...($input.item.json),\n    retryCount: currentRetry + 1,\n    maxRetries: maxRetries,\n    shouldContinue: currentRetry < maxRetries,\n    currentStatus: status\n  }\n};"
      },
