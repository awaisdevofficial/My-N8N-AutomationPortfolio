    {
      "parameters": {
        "jsCode": "// Format final success response\nconst videoUrl = $input.item.json.video_url;\nconst prompt = $('Set Prompt & Config1').item.json.prompt;\nconst predictionId = $('Submit to Replicate (Wan2.1)1').item.json.id;\n\nreturn {\n  json: {\n    success: true,\n    message: \"Video generated successfully with Wan2.1!\",\n    video_url: videoUrl,\n    prediction_id: predictionId,\n    prompt: prompt,\n    model: \"Wan2.1\",\n    timestamp: new Date().toISOString()\n  }\n};"
      },
