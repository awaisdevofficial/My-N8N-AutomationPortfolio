      "parameters": {
        "jsCode": "// Format error/timeout response\nconst status = $input.item.json.status || $input.item.json.currentStatus || 'unknown';\nconst retryCount = $input.item.json.retryCount || 0;\nconst predictionId = $('Submit to Replicate (Wan2.1)1').item.json.id;\n\nreturn {\n  json: {\n    success: false,\n    message: status === 'failed' ? 'Video generation failed' : 'Video generation timed out',\n    status: status,\n    retries_attempted: retryCount,\n    prediction_id: predictionId,\n    timestamp: new Date().toISOString()\n  }\n};"
