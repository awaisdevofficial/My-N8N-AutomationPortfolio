    {
      "parameters": {
        "jsCode": "// Extract video URL from Replicate response\nconst output = $input.item.json.output;\nconst status = $input.item.json.status;\n\n// Replicate returns video as URL or array of URLs\nlet videoUrl = '';\n\nif (Array.isArray(output)) {\n  videoUrl = output[0];\n} else if (typeof output === 'string') {\n  videoUrl = output;\n} else if (output && typeof output === 'object') {\n  videoUrl = output.video || output.url || '';\n}\n\nreturn {\n  json: {\n    success: true,\n    status: status,\n    video_url: videoUrl,\n    output: videoUrl,\n    prediction_id: $('Submit to Replicate (Wan2.1)1').item.json.id,\n    prompt: $('Set Prompt & Config1').item.json.prompt\n  }\n};"
      },
      "id": "4ef25b16-330c-4e63-a561-e74d9c5f7f23",
      "name": "Extract Video URL1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
