    {
      "parameters": {
        "jsCode": "// Initialize output array\nconst results = [];\n\n// Loop through input items (usually just one webhook)\nfor (const item of $input.all()) {\n  const body = item.json.body || {};\n  \n  // 1. GET THE MANDATORY AGENT ID\n  const agentId = body.agent_id || item.json.agent_id || null;\n  \n  // 2. CHECK IF THIS IS A CSV FILE OR SINGLE ENTRY\n  if (body.csv && typeof body.csv === 'string') {\n    \n    // --- CSV PATH: Parse the list ---\n    const rows = body.csv.split(/\\r?\\n/).filter(row => row.trim() !== '');\n    \n    // Extract headers and trim whitespace\n    const headers = rows.shift().split(',').map(h => h.trim());\n    \n    rows.forEach(row => {\n      const values = row.split(',');\n      const rowObject = {};\n      \n      headers.forEach((header, index) => {\n        const value = values[index] ? values[index].trim() : null;\n        \n        // MAP CSV HEADERS TO YOUR REQUIRED KEYS\n        if (header === 'Name') {\n          rowObject['name'] = value;\n        } else if (header === 'PhoneNumber' || header === 'phone') {\n          rowObject['number'] = value;\n        } else {\n          // Keep other columns just in case, or ignore them\n          rowObject[header.toLowerCase()] = value;\n        }\n      });\n      \n      // ATTACH THE AGENT ID TO THIS ROW\n      rowObject['agent_id'] = agentId;\n      results.push({ json: rowObject });\n    });\n    \n  } else {\n    \n    // --- SINGLE ENTRY PATH: Pass it through ---\n    // Check for name in multiple places including metadata\n    const name = body.name || \n                 body.Name || \n                 (body.metadata && body.metadata.caller_name) ||\n                 (body.metadata && body.metadata.name);\n    \n    // Check for number in multiple places\n    const number = body.number || \n                   body.Number || \n                   body.PhoneNumber || \n                   body.phone ||\n                   body.to_number ||\n                   (body.metadata && body.metadata.phone_number);\n    \n    results.push({\n      json: {\n        name: name,\n        number: number,\n        agent_id: agentId\n      }\n    });\n  }\n}\n\nreturn results;"
      },
