        "jsonBody": "{\n  \"name\": \"Medical Scheduling Flow\",\n  \"description\": \"Handles appointment booking and emergency triage\",\n  \"start_speaker\": \"agent\",\n  \"start_node_id\": \"node_greeting\",\n  \"nodes\": [\n    {\n      \"id\": \"node_greeting\",\n      \"type\": \"conversation\",\n      \"instruction\": {\n        \"type\": \"static_text\",\n        \"text\": \"Thank you for calling City Clinic. Are you calling to book an appointment?\"\n      },\n      \"edges\": [\n        {\n          \"destination_node_id\": \"node_booking\",\n          \"transition_condition\": {\n            \"type\": \"prompt\",\n            \"prompt\": \"User wants to book an appointment\"\n          }\n        },\n        {\n          \"destination_node_id\": \"node_end\",\n          \"transition_condition\": {\n            \"type\": \"prompt\",\n            \"prompt\": \"User says no or wants to hang up\"\n          }\n        }\n      ]\n    },\n    {\n      \"id\": \"node_booking\",\n      \"type\": \"conversation\",\n      \"instruction\": {\n        \"type\": \"prompt\",\n        \"text\": \"Ask for the patient preferred date and time.\"\n      },\n      \"edges\": []\n    },\n    {\n      \"id\": \"node_end\",\n      \"type\": \"end\",\n      \"instruction\": {\n        \"type\": \"static_text\",\n        \"text\": \"Goodbye, have a great day.\"\n      }\n    }\n  ]\n}",
